{
  "properties": {
    "platform": {
      "enabled": true
    },
    "globalValidation": {
      "unauthenticatedClientAction": "Return401",
      "redirectToProvider": "AzureActiveDirectory",
      "excludedPaths": [
        "/"
      ]
    },
    "identityProviders": {
      "azureActiveDirectory": {
        "enabled": true,
        "registration": {
          "clientIdSettingName": "WEBSITE_AUTH_CLIENT_ID",
          "clientSecretSettingName": "MICROSOFT_PROVIDER_AUTHENTICATION_SECRET",
          "openIdConnectConfiguration": {
            "wellKnownOpenIdConfiguration": "https://microsoftonline.com"
          }
        }
      }
    }
  }
}
